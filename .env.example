# Servidor
PORT=3333
CDP_PORT=9222
NODE_ENV=development

# Autenticação (PIN de 4-6 dígitos)
MOBILE_PIN=1234

# Ollama — usado pela feature de melhoria de prompt
# Instale Ollama em https://ollama.ai
# Execute: ollama pull deepseek-coder
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-coder

# Telegram bot (opcional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Modelo padrão para melhoria de prompt (legado, para compatibilidade)
IMPROVE_MODEL=claude-haiku-4-5-20251001
